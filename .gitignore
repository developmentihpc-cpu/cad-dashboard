.env
.env.local
*.key
*credentials*.json

# ──────────────────────────────────────────────────────
# Local runtime state and outputs
# ──────────────────────────────────────────────────────
agent_outputs/
*_context.json
digest_preview.html
__pycache__/

# ──────────────────────────────────────────────────────
# Map-rendering skill (~18 MB — bundled boundary data + flags)
# Committed to the repo so Cloud Run gets it on deploy. The skill is large
# but it's the only way the headless container can resolve admin-1 polygons
# at render time. Without this folder in the container, /generate-ppt
# returns X-Map-Status: skipped and ships placeholder rectangles.
# ──────────────────────────────────────────────────────

# Extracted design reference (regeneratable from Claude Design)
design/
*.pyc
*.pyo

# ──────────────────────────────────────────────────────
# Local-only utilities
# ──────────────────────────────────────────────────────
*.bat
node_modules/
package-lock.json
package.json

